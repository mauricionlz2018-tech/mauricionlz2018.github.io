---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/atoms/Footer.astro";
import TechCard from "../components/molecules/TechCard.astro";

const base = import.meta.env.BASE_URL;

---

<Layout>
  <main class="grow px-4 pt-12 font-sans text-[var(--text)]">
    <div class="mx-auto max-w-md">
      <div class="text-center mb-10">
        <h1 class="fade-in text-3xl font-bold tracking-tight">Mis Conocimientos y/o Habilidades</h1>
        <p class="fade-in delay-1 mt-2 text-base text-[var(--text-muted)]">
          Conocimientos y Habilidades que estoy aprendiendo.
        </p>
      </div>

      <div class="space-y-8">
        <div>
          <h2 class="text-lg font-semibold mb-4">Frontend</h2>

          <div class="space-y-3">
            <TechCard name="React" percent={28} />
            <TechCard name="Astro" percent={30} />
            <TechCard name="Tailwind CSS" percent={25} />
            <TechCard name="HTML y CSS" percent={60} />
          </div>
        </div>

        <div>
          <h2 class="text-lg font-semibold mb-4">Backend</h2>

          <div class="space-y-3">
            <TechCard name="Node.js" percent={50} />
            <TechCard name="Python (Django)" percent={40} />
          </div>
        </div>

        <div>
          <h2 class="text-lg font-semibold mb-4">Diseño</h2>

          <div class="space-y-3">
            <div class="skill">
              <span>Figma</span>
              <div class="bar"><div class="fill" style="--w: 82%"></div></div>
            </div>
            <div class="skill">
              <span>Adobe XD</span>
              <div class="bar"><div class="fill" style="--w: 68%"></div></div>
            </div>
            <div class="skill">
              <span>UI/UX</span>
              <div class="bar"><div class="fill" style="--w: 75%"></div></div>
            </div>
            <div class="skill">
              <span>Blender</span>
              <div class="bar"><div class="fill" style="--w: 45%"></div></div>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-lg font-semibold mb-4">Otras Herramientas</h2>

          <div class="space-y-3">
            <div class="skill">
              <span>GitHub</span>
              <div class="bar"><div class="fill" style="--w: 88%"></div></div>
            </div>
            <div class="skill">
              <span>Docker</span>
              <div class="bar"><div class="fill" style="--w: 55%"></div></div>
            </div>
            <div class="skill">
              <span>Linux</span>
              <div class="bar"><div class="fill" style="--w: 64%"></div></div>
            </div>
            <div class="skill">
              <span>MySQL</span>
              <div class="bar"><div class="fill" style="--w: 72%"></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
    <center><footer class="text-sm text-[var(--text-muted)]"> 2025 &copy; Todos los derechos reservados "Mauricio Nolazco Lonjino"</footer></center>


  <Footer />
</Layout>
