---
import Layout from '../layouts/Layout.astro';
import Button from '../components/templates/button.astro';
import Footer from '../components/atoms/Footer.astro';
import IconButton from '../components/atoms/IconButton.astro';
import Avatar from '../components/molecules/Avatar.astro';
import ContactForm from '../components/molecules/ContactForm.astro';

const base = import.meta.env.BASE_URL;
const cvHref = `${base}cv-mauricio-nolazco.txt`;

---
<Layout>


  <main class="grow pt-16 px-4">
    <div class="flex w-full flex-col items-center gap-10 text-center">

      <div class="relative flex flex-col items-center gap-4">

        <div class="absolute -top-4 -left-12 h-16 w-16 rounded-full bg-[var(--primary)]/20 blur-xl"></div>
        <div class="absolute -bottom-4 -right-12 h-16 w-16 rounded-full bg-[var(--secondary)]/20 blur-xl"></div>

        <Avatar src={`${base}/assets/images/Yo.jpeg`} alt="Foto de Mi" />

        <div class="flex flex-col">
          <h1 class="fade-in text-3xl font-bold">
            Mi persona
          </h1>
          <p class="fade-in delay-1 text-base text-[var(--text-muted)]">
            Mauricio Nolazco Lonjino
          </p>
        </div>
      </div>

      <div class="w-full max-w-md space-y-6 text-left">
        <h2 class="fade-in text-lg font-semibold">Sobre mi</h2>
        <p class="fade-in text-base leading-relaxed text-[var(--text-muted)]">
          Soy un estudiante de Ingeniería en Sistemas Computacionales apasionado por crear soluciones funcionales y visualmente atractivas. 
          Me enfoco en el desarrollo web utilizando tecnologías modernas y disfruto aprender constantemente nuevas herramientas que me permitan mejorar y expandir mis habilidades.
        </p>
        <h2 class="fade-in text-lg font-semibold">Autobiografia</h2>
        <p class="fade-in text-[var(--text-muted)]">
            Naci el día 04 de Junio de 2004, en el municipio de San José del Rincón, Estado de México.
            Desde pequeño he estado interesado por la tecnología aunque no tenia mucho conocimeinto de ella, me gustaba
            saber como funcionaba ya sea con artefactos que el día de hoy son obsoletos como radios, televisiones y celulares.
        </p>
        <h2 class="fade-in text-lg font-semibold">Mision</h2>
        <p class="fade-in text-[var(--text-muted)]">Mi objetivo es seguir desarrollando proyectos que resuelvan problemas reales, mejorar mi experiencia en frontend/backend y colaborar en equipos donde pueda crecer profesionalmente.</p>
        <h2 class="fade-in text-lg font-semibold">Habilidades</h2>
        <p class="fade-in text-[var(--text-muted)]">Tengo experiencia trabajando con HTML, CSS, JavaScript, Python, MySQL y frameworks como Node.js. 
            También he participado en el desarrollo de interfaces, sistemas escolares y plataformas pequeñas de gestión.</p>
        <h2 class="fade-in text-lg font-semibold">Estudios</h2>
        <p class="fade-in text-[var(--text-muted)]">Actualmente estudio en la Universidad Mexiquense del Bicentenario, curso el septimo semestre de la carrera de Ingeniería en Sistemas Computacionales.</p>

        <a
          href={cvHref}
          download
          class="inline-flex items-center justify-center rounded-full bg-[var(--primary)] px-5 py-3 font-semibold text-slate-950 transition-all duration-300 hover:-translate-y-0.5 hover:bg-[var(--secondary)]"
        >
          Descargar CV
        </a>
      </div>
    </div>
  </main>

  <ContactForm />
    <center><footer class="text-sm text-[var(--text-muted)]"> 2025 &copy; Todos los derechos reservados "Mauricio Nolazco Lonjino"</footer></center>


  <Footer />


</Layout>
