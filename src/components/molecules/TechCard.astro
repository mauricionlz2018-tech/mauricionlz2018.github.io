---
interface Props {
  name: string;
  percent: number;
}

const { name, percent } = Astro.props;
---

<div class="skill">
  <span class="text-sm font-medium text-[var(--text)]">{name}</span>
  <div class="bar">
    <div
      class="fill"
      style={`--w: ${percent}%;`}
    ></div>
  </div>
</div>
